{
    "name": "d076/sanctum-refresh-tokens",
    "description": "Refresh token realization for laravel sanctum",
    "keywords": ["laravel", "sanctum", "auth"],
    "type": "library",
    "authors": [
        {
            "name": "Dmitry Titov",
            "email": "dezmond076@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "illuminate/auth": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/notifications": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "laravel/sanctum": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "larastan/larastan": "^3.9"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "D076\\SanctumRefreshTokens\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "D076\\SanctumRefreshTokens\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "D076\\SanctumRefreshTokens\\Providers\\SanctumRefreshServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
